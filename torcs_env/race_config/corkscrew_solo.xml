<?xml version="1.0" encoding="UTF-8"?>
<!-- Configurazione TORCS Quick Race: circuito Corkscrew, singolo driver SCR.
     Il numero di giri effettivi è deciso lato client Python (flag "laps" degli
     script); "laps" qui sotto è volutamente alto (999) per evitare che TORCS
     termini la gara da solo prima che il client abbia finito.
     Avvio: torcs -r path/to/corkscrew_solo.xml
     Il plugin server SCR resta in ascolto sulla porta UDP 3001 per il client Python. -->
<!DOCTYPE params SYSTEM "params.dtd">
<params name="Quick Race">
  <section name="Header">
    <attstr name="name"            val="Quick Race"/>
    <attstr name="description"     val="Corkscrew solo lap — AI training"/>
    <attnum name="priority"        val="10"/>
    <attstr name="author"          val="torcs-ai"/>
  </section>

  <section name="Tracks">
    <section name="1">
      <attstr name="name"     val="corkscrew"/>
      <attstr name="category" val="road"/>
    </section>
  </section>

  <section name="Races">
    <section name="1">
      <attstr name="name"     val="Quick Race"/>
      <attstr name="type"     val="race"/>
      <attnum name="laps"     val="999"/>
      <attstr name="start"    val="standing"/>
      <attnum name="fuel"     val="0"/>   <!-- 0 = nessun consumo di carburante -->
      <attnum name="damage"   val="0"/>   <!-- 0 = nessun modello di danno      -->
    </section>
  </section>

  <section name="Drivers">
    <section name="1">
      <attnum name="idx"      val="0"/>
      <attstr name="module"   val="scr_server"/>
      <attstr name="name"     val="SCR Server 0"/>
    </section>
  </section>

  <section name="Configuration">
    <section name="1">
      <!-- QuickRace gira headless quando invocato con il flag -r -->
      <attstr name="type" val="race"/>
    </section>
  </section>
</params>
